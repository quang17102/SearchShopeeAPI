{
  "manifest_version": 3,
  "name": "Shopee Auto Search",
  "version": "1.3",
  "description": "Tự động search Shopee và lấy danh sách sản phẩm từ API",
  "permissions": ["activeTab", "tabs", "alarms"],
  "host_permissions": [
    "https://shopee.vn/*",
    "https://*.shopee.vn/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shopee Search"
  },
  "content_scripts": [
    {
      "matches": ["https://shopee.vn/*", "https://*.shopee.vn/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject-search.js"],
      "matches": ["https://shopee.vn/*", "https://*.shopee.vn/*"]
    }
  ]
}
